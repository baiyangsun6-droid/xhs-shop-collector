{
  "name": "xhs-shop-collector",
  "version": "0.1.0",
  "description": "本地运行的小红书店铺商品采集与飞书多维表格写入工具",
  "author": "Baiyang",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite --host 127.0.0.1",
    "server": "node server/index.mjs",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "desktop:icon": "node scripts/build-icon.mjs",
    "desktop:sign": "node scripts/sign-mac.mjs",
    "package:mac": "npm run build && npm run desktop:icon && electron-builder --mac dir --arm64 && npm run desktop:sign",
    "start": "node server/index.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "xhs:login": "node server/cli.mjs login",
    "collect": "node server/cli.mjs collect",
    "collect:batch": "node server/cli.mjs collect-batch"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "lucide-react": "0.468.0",
    "playwright": "1.56.1",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "vite": "6.4.3"
  },
  "build": {
    "appId": "com.baiyang.xhs-shop-collector",
    "productName": "小红书商品采集器",
    "electronDist": "node_modules/electron/dist",
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright/**/*",
      "node_modules/playwright-core/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/app-icon.icns",
      "target": [
        "dir"
      ],
      "identity": null
    }
  }
}
